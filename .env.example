# Supabase — client-safe values only (anon key is public by design)
# Copy this file to .env.local and fill in real values from your Supabase project:
#   Supabase Dashboard -> Project Settings -> API
#
# NEVER put the service_role key in this project. It is not needed in Phase 1
# and must never be exposed to browser code.

NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Optional (invitations) ---
# Public base URL used to build invite links. If unset, links are derived
# from the request host (fine for local dev).
NEXT_PUBLIC_SITE_URL=

# Server-only. If both are set, invitation emails are sent via Resend.
# If unset, invites still work — the admin gets a copyable invite link.
# Never expose these to the browser (no NEXT_PUBLIC_ prefix).
RESEND_API_KEY=
INVITE_EMAIL_FROM=
