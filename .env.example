# Supabase — client-safe values only (anon key is public by design)
# Copy this file to .env.local and fill in real values from your Supabase project:
#   Supabase Dashboard -> Project Settings -> API
#
# NEVER put the service_role key in this project. It is not needed in Phase 1
# and must never be exposed to browser code.

NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Invitations ---
# Server-only. Base URL used to build invite links (e.g. https://app.example.com
# — no trailing slash). Required in production: set it in Vercel so invite
# links always point at the real deployed app, never at whatever host/domain
# served the request. Leave unset in local dev — links fall back to
# http://localhost:3000 automatically.
APP_URL=

# Server-only. Required for automatic invitation email delivery via Resend.
# If either is unset, pressing Invite fails with a clear error instead of
# silently falling back to a manual link. Never expose these to the browser
# (no NEXT_PUBLIC_ prefix).
#
# While using Resend's shared test domain (onboarding@resend.dev), delivery
# only succeeds to the email address on your own Resend account — switch
# INVITE_EMAIL_FROM to a verified domain before inviting real users.
RESEND_API_KEY=
INVITE_EMAIL_FROM=onboarding@resend.dev
