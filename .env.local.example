# Copy this file to .env.local (which is gitignored and never committed)
# and replace the placeholders with your real Supabase project values.
#
# The service_role key is intentionally absent — do not add it here.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# Required for automatic invitation email delivery via Resend (see
# .env.example for details). Without these, pressing Invite fails with a
# clear error instead of falling back to a manual link.
RESEND_API_KEY=re_your_resend_api_key
INVITE_EMAIL_FROM=onboarding@resend.dev
